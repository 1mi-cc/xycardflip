APP_ENV=dev
APP_NAME=Card Flip Assistant API
API_HOST=0.0.0.0
API_PORT=8000
SQLITE_PATH=./data/trading.db

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# RAGFlow bridge
RAGFLOW_ENABLED=false
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=
RAGFLOW_CHAT_ID=
RAGFLOW_TIMEOUT_SEC=45

# Trading constraints
PLATFORM_FEE_RATE=0.06
DEFAULT_SHIPPING_COST=8.0
MIN_PROFIT=20.0
MIN_ROI=0.12
RISK_DISCOUNT=0.05
RISK_BLOCK_SCORE=70
RISK_REVIEW_SCORE=40
RISK_MIN_MODEL_CONFIDENCE=0.45
RISK_MIN_COMPARABLES=6
RISK_MAX_CI_SPREAD_RATIO=0.35
RISK_MIN_MARGIN_RATIO=0.08
RISK_SELLER_OPEN_LISTING_LIMIT=12
RISK_KEYWORD_PENALTY=18
RISK_SUSPICIOUS_KEYWORDS=urgent sale,quick sale,private chat,vx,wechat,prepay,outside platform,offline deal

# Strategy thresholds
STRATEGY_PROFILE=balanced
STRATEGY_MIN_SCORE=
STRATEGY_MIN_ROI=
STRATEGY_MAX_RISK_SCORE=
STRATEGY_ALLOW_BLOCKED_REVIEW=
STRATEGY_AUTO_REJECT_UNQUALIFIED=
STRATEGY_AGGRESSIVE_MIN_SCORE=50
STRATEGY_AGGRESSIVE_MIN_ROI=0.08
STRATEGY_AGGRESSIVE_MAX_RISK_SCORE=55
STRATEGY_AGGRESSIVE_ALLOW_BLOCKED_REVIEW=true
STRATEGY_AGGRESSIVE_AUTO_REJECT_UNQUALIFIED=false
STRATEGY_BALANCED_MIN_SCORE=60
STRATEGY_BALANCED_MIN_ROI=0.12
STRATEGY_BALANCED_MAX_RISK_SCORE=40
STRATEGY_BALANCED_ALLOW_BLOCKED_REVIEW=true
STRATEGY_BALANCED_AUTO_REJECT_UNQUALIFIED=true
STRATEGY_CONSERVATIVE_MIN_SCORE=70
STRATEGY_CONSERVATIVE_MIN_ROI=0.18
STRATEGY_CONSERVATIVE_MAX_RISK_SCORE=30
STRATEGY_CONSERVATIVE_ALLOW_BLOCKED_REVIEW=false
STRATEGY_CONSERVATIVE_AUTO_REJECT_UNQUALIFIED=true

# Pricing strategy
PRICING_AGE_DISCOUNT_PER_DAY=0.003
PRICING_MAX_AGE_DISCOUNT=0.18
PRICING_INVENTORY_SOFT_CAP=25
PRICING_STALE_DAYS=3
PRICING_URGENT_DAYS=7
PRICING_MODE_BALANCED_FACTOR=1.00
PRICING_MODE_FAST_EXIT_FACTOR=0.96
PRICING_MODE_PROFIT_MAX_FACTOR=1.05
PRICING_VOLATILITY_DISCOUNT_FACTOR=0.25
PRICING_MAX_VOLATILITY_DISCOUNT=0.10

# Market monitor
MONITOR_TARGET_URL=https://api.mock-market.com/v1/search/items?keyword=card
MONITOR_TIMEOUT_SEC=10
MONITOR_MIN_DELAY_SEC=1.5
MONITOR_MAX_DELAY_SEC=4.5
MONITOR_LONG_REST_PROBABILITY=0.05
MONITOR_LONG_REST_MIN_SEC=10
MONITOR_LONG_REST_MAX_SEC=30
MONITOR_PROVIDER=xianyu
XIAN_YU_SEARCH_URL=https://s.m.xianyu.com/search.htm
# Multi-keyword supported (comma/semicolon/newline separated). Duplicates are auto-deduped.
XIAN_YU_KEYWORDS=咸鱼之王功法,咸鱼之王洗练石,咸鱼之王珍珠
# Backward-compatible single keyword fallback
XIAN_YU_KEYWORD=咸鱼之王功法
XIAN_YU_COOKIE=
XIAN_YU_COOKIE_PROVIDER_URL=http://127.0.0.1:5000/api/cookies/latest
XIAN_YU_COOKIE_REFRESH_URL=http://127.0.0.1:5000/api/cookies/refresh
XIAN_YU_COOKIE_REFRESH_ON_START=false
XIAN_YU_COOKIE_TTL_SEC=540
MONITOR_MAX_PRICE=100
MONITOR_DAY_DELAY_MIN=15
MONITOR_DAY_DELAY_MAX=30
MONITOR_PEAK_DELAY_MIN=3
MONITOR_PEAK_DELAY_MAX=8
MONITOR_NIGHT_DELAY_MIN=25
MONITOR_NIGHT_DELAY_MAX=45
MONITOR_CIRCUIT_MAX_ERRORS=3
MONITOR_CIRCUIT_403_THRESHOLD=2
MONITOR_CIRCUIT_COOLDOWN_SEC=900
MONITOR_AUTO_SCAN_AFTER_INGEST=false
MONITOR_AUTO_SCAN_LIMIT=80
MONITOR_HEALTH_WINDOW_SIZE=40
MONITOR_HEALTH_MIN_SAMPLES=10
MONITOR_HEALTH_MIN_SUCCESS_RATE=0.35
MONITOR_USER_AGENTS=
AUTO_START_MONITOR=false
MONITOR_PAGES=2
MONITOR_USE_PROXY_POOL=false
PROXY_POOL_API=http://127.0.0.1:8899/
PROXY_POOL_PARAMS=types=0&count=3
LOCAL_PROXY_URL=
NETWORK_IGNORE_ENV_PROXY=true
NETWORK_FORCE_PROXY_ONLY=true
# Highest priority outbound proxy (ip:port or http://ip:port). If set, overrides pool/local.
NETWORK_FORCE_PROXY_URL=
PROXY_BAD_TTL_SEC=600
PROXY_BAD_TTL_JITTER_SEC=30
PROXY_MAX_FAILURES=2
PROXY_ROTATION_COOLDOWN_SEC=2
XIAN_YU_MOBILE_USER_AGENT=
XIAN_YU_DESKTOP_USER_AGENT=
XIAN_YU_ACCEPT_LANGUAGE=zh-CN,zh;q=0.9
XIAN_YU_MTOP_APP_KEY=34839810
XIAN_YU_MTOP_API=mtop.taobao.idlemtopsearch.pc.search
XIAN_YU_MTOP_URL=https://h5api.m.goofish.com/h5/mtop.taobao.idlemtopsearch.pc.search/1.0/

# Execution adapter (default mock, can switch to webhook)
EXECUTION_PROVIDER=mock
EXECUTION_TIMEOUT_SEC=8
EXECUTION_AUTH_TOKEN=
EXECUTION_WEBHOOK_SECRET=
EXECUTION_WEBHOOK_MAX_RETRIES=2
EXECUTION_WEBHOOK_RETRY_BACKOFF_SEC=1.5
EXECUTION_WEBHOOK_BUY_URL=
EXECUTION_WEBHOOK_LIST_URL=
EXECUTION_WEBHOOK_SELL_URL=
EXECUTION_LIVE_ENABLED=false
EXECUTION_LIVE_CONFIRM_TOKEN=
EXECUTION_LIVE_MAX_BUY_PRICE=0
EXECUTION_LIVE_MIN_LIST_PROFIT_RATIO=0
EXECUTION_LIVE_MIN_SELL_PROFIT_RATIO=0
EXECUTION_RETRY_ENABLED=false
EXECUTION_RETRY_INTERVAL_SEC=45
EXECUTION_RETRY_BATCH_SIZE=20
EXECUTION_RETRY_ACTION=all
EXECUTION_RETRY_DRY_RUN=true
EXECUTION_RETRY_FORCE=false
EXECUTION_RETRY_CONFIRM_TOKEN=
EXECUTION_BUSINESS_BAN_STATUS_CODES=401,403,407,418,423,429
EXECUTION_BUSINESS_BAN_CODES=BIZ_BAN,RISK_BLOCK,SECURITY_BLOCK,ACCOUNT_LIMIT,FREQUENCY_LIMIT
EXECUTION_AUTO_ROTATE_PROXY_ON_BAN=true
AUTOMATION_DEFAULT_INCLUDE_MONITOR=true
AUTOMATION_DEFAULT_INCLUDE_SCAN=true
AUTOMATION_DEFAULT_INCLUDE_AUTOTRADE=true
AUTOMATION_DEFAULT_INCLUDE_EXECUTION_RETRY=true
AUTOMATION_DEFAULT_SCAN_LIMIT=120

# VNPY-style scanner
VNPY_SCAN_INTERVAL_SEC=300
VNPY_SCAN_PAGES=2

# Auto trade approval (safe defaults: disabled)
AUTO_APPROVE_ENABLED=false
AUTO_APPROVE_INTERVAL_SEC=30
AUTO_APPROVE_BATCH_SIZE=10
AUTO_APPROVE_MIN_SCORE=75
AUTO_APPROVE_MIN_ROI=0.18
AUTO_APPROVE_MAX_RISK_SCORE=30
AUTO_APPROVE_REQUIRE_RISK_SCORE=true
AUTO_APPROVE_APPROVED_BY=autotrade_bot
AUTO_APPROVE_NOTE=auto approved by service
AUTO_EXECUTE_BUY_ON_APPROVE=false
AUTO_EXECUTE_BUY_DRY_RUN=true
AUTO_EXECUTE_LIST_ON_BUY_SUCCESS=false
AUTO_EXECUTE_LIST_DRY_RUN=true
AUTO_START_AUTOTRADE=false
AUTO_START_EXECUTION_RETRY=false

ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

